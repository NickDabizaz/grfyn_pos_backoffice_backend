<div class="mb-6">
  <h1 class="text-xl font-bold text-white">DB Query Console</h1>
  <p class="text-sm text-gray-500 mt-1">Full-access SQL runner — all queries are logged</p>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
  <form method="POST" action="/developer/db-console" class="space-y-3">
    <textarea name="query" rows="6" placeholder="SELECT * FROM tenant WHERE status = 'AKTIF'&#10;-- Or any SQL: INSERT, UPDATE, DELETE, DROP, etc."
      class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-sm text-white font-mono focus:outline-none focus:ring-2 focus:ring-orange-500 resize-y"><%= query %></textarea>
    <div class="flex items-center justify-between">
      <span class="text-xs text-gray-500">Timeout: 10s | Max rows: 1000 | All queries are logged</span>
      <button type="submit" class="bg-orange-600 hover:bg-orange-500 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2">
        <i data-lucide="play" class="w-4 h-4"></i> Run Query
      </button>
    </div>
  </form>
</div>

<% if (locals.error) { %>
  <div class="mb-4 p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
    <div class="flex items-center gap-2 mb-1"><i data-lucide="alert-triangle" class="w-4 h-4 text-red-400"></i><span class="text-sm font-medium text-red-400">Error</span></div>
    <pre class="text-xs text-red-300 font-mono whitespace-pre-wrap"><%= error %></pre>
  </div>
<% } %>

<% if (result) { %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-800 flex items-center justify-between">
      <span class="text-sm text-gray-400">
        Result:
        <% if (result.columns) { %>
          <span class="text-white font-mono"><%= rowCount %></span> rows
          <% if (result.hasMore) { %><span class="text-yellow-400"> (limited to <%= rowCount %>)</span><% } %>
        <% } else { %>
          <span class="text-white font-mono"><%= result.affectedRows %></span> rows affected
        <% } %>
        — <span class="text-white font-mono"><%= elapsed %></span> ms
      </span>
    </div>
    <% if (result.columns && result.columns.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead><tr class="border-b border-gray-800"><% result.columns.forEach(col => { %><th class="text-left px-3 py-2.5 text-xs font-medium text-gray-400 uppercase font-mono"><%= col %></th><% }); %></tr></thead>
          <tbody class="divide-y divide-gray-800">
            <% result.rows.forEach(row => { %><tr class="hover:bg-gray-800/50 transition-colors"><% result.columns.forEach(col => { %><td class="px-3 py-2 text-xs text-gray-300 font-mono max-w-xs truncate"><%= row[col] !== null && row[col] !== undefined ? String(row[col]) : 'NULL' %></td><% }); %></tr><% }); %>
          </tbody>
        </table>
      </div>
      <% if (result.rows.length === 0) { %><div class="p-8 text-center text-gray-500">Empty result set</div><% } %>
    <% } else if (result.affectedRows !== undefined) { %>
      <div class="p-4 text-green-400 text-sm">Query executed successfully. <%= result.affectedRows %> row(s) affected.</div>
    <% } %>
  </div>
<% } %>

<script>if(typeof lucide!=='undefined'){lucide.createIcons();}</script>
