<% if (locals.error) { %>
  <div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"><%= error %></div>
<% } %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-white">Tenant Overview</h1>
  <p class="text-sm text-gray-500 mt-1">All tenants with aggregate statistics</p>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
  <% if (tenants.length === 0) { %>
    <div class="p-12 text-center text-gray-500">
      <i data-lucide="building-2" class="w-10 h-10 mx-auto mb-2 text-gray-600"></i>
      <p>No tenants found</p>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800">
            <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">ID</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Tenant</th>
            <th class="text-center px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Users</th>
            <th class="text-center px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Lokasi</th>
            <th class="text-center px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Trans Jual</th>
            <th class="text-center px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Trans Beli</th>
            <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Last Activity</th>
            <th class="text-center px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% tenants.forEach(t => { %>
          <tr class="hover:bg-gray-800/50 transition-colors">
            <td class="px-4 py-3 text-gray-400 font-mono text-xs"><%= t.idtenant %></td>
            <td class="px-4 py-3">
              <div class="text-white font-medium"><%= t.namatenant %></div>
              <div class="text-xs text-gray-500"><%= t.hp || '-' %></div>
            </td>
            <td class="px-4 py-3 text-center text-white"><%= t.jml_user %></td>
            <td class="px-4 py-3 text-center text-white"><%= t.jml_lokasi %></td>
            <td class="px-4 py-3 text-center text-white"><%= t.jml_jual %></td>
            <td class="px-4 py-3 text-center text-white"><%= t.jml_beli %></td>
            <td class="px-4 py-3 text-xs text-gray-400">
              <% const la = [t.last_jual, t.last_beli].filter(Boolean).sort().reverse(); %>
              <%= la.length > 0 ? new Date(la[0]).toLocaleDateString('id-ID') : '-' %>
            </td>
            <td class="px-4 py-3 text-center">
              <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium <%= t.status === 'AKTIF' ? 'bg-green-500/10 text-green-400' : 'bg-red-500/10 text-red-400' %>"><%= t.status %></span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>if(typeof lucide!=='undefined'){lucide.createIcons();}</script>
