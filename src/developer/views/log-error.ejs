<% if (locals.error) { %>
  <div class="mb-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"><%= error %></div>
<% } %>

<div class="mb-6">
  <h1 class="text-xl font-bold text-white">Log Error Viewer</h1>
  <p class="text-sm text-gray-500 mt-1">Browse error log files (JSON Lines)</p>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
  <form method="GET" action="/developer/logs/error" class="flex flex-wrap gap-3 items-end">
    <div>
      <label class="block text-xs text-gray-400 mb-1">Log File</label>
      <select name="date" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
        <option value="">-- Pilih --</option>
        <% files.forEach(f => { %>
          <% const d = f.replace('error-', '').replace('.log', ''); %>
          <option value="<%= d %>" <%= date === d ? 'selected' : '' %>><%= d %></option>
        <% }); %>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Search</label>
      <input type="text" name="search" value="<%= search %>" placeholder="Keyword..." class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-white w-48 focus:outline-none focus:ring-2 focus:ring-orange-500">
    </div>
    <button type="submit" class="bg-gray-800 hover:bg-gray-700 border border-gray-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">Filter</button>
    <% if (selectedFile) { %>
      <a href="/developer/logs/error/download?file=<%= selectedFile %>" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition-colors inline-flex items-center gap-2">
        <i data-lucide="download" class="w-4 h-4"></i> Download
      </a>
    <% } %>
  </form>
</div>

<% if (selectedFile) { %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-800 flex items-center justify-between">
      <span class="text-sm text-gray-400">File: <span class="text-white font-mono"><%= selectedFile %>.log</span> — <%= totalLines %> entries</span>
      <span class="text-xs text-gray-500">Page <%= currentPage %> / <%= totalPages %></span>
    </div>
    <% if (lines.length === 0) { %>
      <div class="p-8 text-center text-gray-500">
        <i data-lucide="inbox" class="w-10 h-10 mx-auto mb-2 text-gray-600"></i>
        <p>No entries found</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-800">
              <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase w-48">Timestamp</th>
              <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase w-16">Level</th>
              <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase">Message</th>
              <th class="text-left px-4 py-2.5 text-xs font-medium text-gray-400 uppercase w-24">Path</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800 font-mono">
            <% lines.forEach(line => { %>
            <tr class="hover:bg-gray-800/50 transition-colors">
              <td class="px-4 py-2 text-xs text-gray-500 whitespace-nowrap"><%= line.ts ? new Date(line.ts).toLocaleString('id-ID') : '-' %></td>
              <td class="px-4 py-2">
                <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-red-500/10 text-red-400"><%= line.level || 'error' %></span>
              </td>
              <td class="px-4 py-2 text-xs text-gray-300 max-w-md truncate"><%= line.message || line.raw || '-' %></td>
              <td class="px-4 py-2 text-xs text-gray-500"><%= line.path || '-' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (totalPages > 1) { %>
      <div class="px-4 py-3 border-t border-gray-800 flex items-center justify-center gap-2">
        <% if (currentPage > 1) { %>
          <a href="?date=<%= date %>&search=<%= search %>&page=<%= currentPage - 1 %>" class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 rounded text-sm text-gray-300 transition-colors">Prev</a>
        <% } %>
        <span class="text-sm text-gray-500">Page <%= currentPage %> of <%= totalPages %></span>
        <% if (currentPage < totalPages) { %>
          <a href="?date=<%= date %>&search=<%= search %>&page=<%= currentPage + 1 %>" class="px-3 py-1.5 bg-gray-800 hover:bg-gray-700 rounded text-sm text-gray-300 transition-colors">Next</a>
        <% } %>
      </div>
    <% } %>
  </div>
<% } else { %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-12 text-center">
    <i data-lucide="file-text" class="w-12 h-12 mx-auto mb-3 text-gray-600"></i>
    <h3 class="text-lg font-semibold text-white mb-1">Select a log file</h3>
    <p class="text-sm text-gray-500">Choose a date from the dropdown above to view error logs</p>
    <% if (files.length === 0) { %>
      <p class="text-sm text-gray-600 mt-4">No log files found yet</p>
    <% } %>
  </div>
<% } %>

<script>if(typeof lucide!=='undefined'){lucide.createIcons();}</script>
