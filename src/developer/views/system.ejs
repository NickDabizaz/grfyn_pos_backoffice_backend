<div class="mb-6">
  <h1 class="text-xl font-bold text-white">System Monitoring</h1>
  <p class="text-sm text-gray-500 mt-1">CPU, memory, uptime — auto-refresh every 5 seconds</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
      <i data-lucide="cpu" class="w-4 h-4 text-purple-400"></i> CPU
    </h2>
    <div class="space-y-3">
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-400">Load Avg (1m)</span>
          <span class="text-green-400 font-mono"><%= cpu.load1 %></span>
        </div>
        <div class="w-full bg-gray-800 rounded-full h-2">
          <div class="bg-purple-500 h-2 rounded-full transition-all" style="width: <%= Math.min(parseFloat(cpu.load1) / cpu.cores * 100, 100) %>%"></div>
        </div>
      </div>
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-400">Load Avg (5m)</span>
          <span class="text-gray-400 font-mono"><%= cpu.load5 %></span>
        </div>
        <div class="w-full bg-gray-800 rounded-full h-2">
          <div class="bg-purple-400 h-2 rounded-full" style="width: <%= Math.min(parseFloat(cpu.load5) / cpu.cores * 100, 100) %>%"></div>
        </div>
      </div>
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-400">Load Avg (15m)</span>
          <span class="text-gray-400 font-mono"><%= cpu.load15 %></span>
        </div>
        <div class="w-full bg-gray-800 rounded-full h-2">
          <div class="bg-purple-300 h-2 rounded-full" style="width: <%= Math.min(parseFloat(cpu.load15) / cpu.cores * 100, 100) %>%"></div>
        </div>
      </div>
    </div>
    <div class="mt-4 text-xs text-gray-500">Cores: <%= cpu.cores %> | Arch: <%= arch %> | Host: <%= hostname %></div>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
      <i data-lucide="hard-drive" class="w-4 h-4 text-yellow-400"></i> Memory (OS)
    </h2>
    <div class="space-y-3">
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-400">Used <%= memory.used %> GB / <%= memory.total %> GB</span>
          <span class="text-green-400 font-mono"><%= memory.percent %>%</span>
        </div>
        <div class="w-full bg-gray-800 rounded-full h-2">
          <div class="h-2 rounded-full transition-all bg-green-500" style="width: <%= memory.percent %>%"></div>
        </div>
      </div>
      <div class="flex justify-between text-xs"><span class="text-gray-400">Free: <span class="text-white font-mono"><%= memory.free %> GB</span></span></div>
    </div>

    <h2 class="text-sm font-semibold text-white mb-4 mt-6 flex items-center gap-2">
      <i data-lucide="brain" class="w-4 h-4 text-teal-400"></i> Heap (Node.js)
    </h2>
    <div class="space-y-3">
      <div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-400">Used <%= heap.used %> MB / <%= heap.total %> MB</span>
          <span class="text-teal-400 font-mono"><%= heap.percent %>%</span>
        </div>
        <div class="w-full bg-gray-800 rounded-full h-2">
          <div class="bg-teal-500 h-2 rounded-full" style="width: <%= heap.percent %>%"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
      <i data-lucide="clock" class="w-4 h-4 text-blue-400"></i> Uptime
    </h2>
    <div class="space-y-4">
      <div><div class="text-xs text-gray-500 mb-1">OS Uptime</div><div class="text-2xl font-bold text-white"><%= uptime.os %></div></div>
      <div><div class="text-xs text-gray-500 mb-1">Process Uptime</div><div class="text-2xl font-bold text-white"><%= uptime.process %></div></div>
    </div>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
      <i data-lucide="info" class="w-4 h-4 text-gray-400"></i> Info
    </h2>
    <div class="space-y-3">
      <div class="flex justify-between"><span class="text-sm text-gray-400">Node.js</span><span class="text-sm text-white font-mono"><%= nodeVersion %></span></div>
      <div class="flex justify-between"><span class="text-sm text-gray-400">Platform</span><span class="text-sm text-white font-mono"><%= platform %></span></div>
      <div class="flex justify-between"><span class="text-sm text-gray-400">Architecture</span><span class="text-sm text-white font-mono"><%= arch %></span></div>
      <div class="flex justify-between"><span class="text-sm text-gray-400">Hostname</span><span class="text-sm text-white font-mono"><%= hostname %></span></div>
    </div>
  </div>
</div>

<script>
  if(typeof lucide!=='undefined'){lucide.createIcons();}
  setTimeout(function(){ window.location.reload(); }, 5000);
</script>
