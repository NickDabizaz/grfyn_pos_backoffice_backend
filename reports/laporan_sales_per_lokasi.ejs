<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Penjualan Per Lokasi</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    .filter-tags { margin-bottom: 8px; }
    .filter-tags .tag { display:inline-block; background:#FAEFE5; color:#C4683D; padding:2px 8px; border-radius:10px; font-size:10px; font-weight:600; margin:2px; }

    .lokasi-group-header {
      background-color: #C4683D;
      color: white;
      padding: 8px 12px;
      border-radius: 8px 8px 0 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 25px;
      font-weight: bold;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .lokasi-group-header .tag-code { background: rgba(255,255,255,0.2); padding: 2px 6px; border-radius: 4px; margin-right: 8px; font-size: 12px; }

    table { width: 100%; border-collapse: collapse; margin-bottom: 0; }
    th, td { border: 1px solid #D7CAC1; padding: 6px 4px; font-size: 10px; }
    th { background-color: #f8f9fa; }
    td.rs { vertical-align: top; background-color: #ffffff; }
    td.item { background-color: #ffffff; }

    .status-badge { padding: 2px 6px; border-radius: 4px; font-size: 9px; font-weight: bold; display: inline-block; }
    .status-badge.lunas { background: #DCFCE7; color: #166534; }
    .status-badge.belum { background: #FEE2E2; color: #991B1B; }

    .center { text-align: center; }
    .right { text-align: right; }
    .subtotal-row { background-color: #FCF8F5; font-weight: bold; }

    .grand-total-banner {
      background-color: #C4683D;
      color: white;
      padding: 12px;
      border-radius: 8px;
      margin-top: 20px;
      display: flex;
      justify-content: space-between;
      font-size: 14px;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN PENJUALAN PER LOKASI (DETAIL)</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <% if (kodelokasi || namalokasi || kodecustomer || namacustomer || statusLunas) { %>
  <div class="filter-tags">
    <% if (kodelokasi) { %><span class="tag">Lokasi: <%= kodelokasi %></span><% } %>
    <% if (namalokasi) { %><span class="tag">Lokasi: <%= namalokasi %></span><% } %>
    <% if (kodecustomer) { %><span class="tag">Customer: <%= kodecustomer %></span><% } %>
    <% if (namacustomer) { %><span class="tag">Customer: <%= namacustomer %></span><% } %>
    <% if (statusLunas) { %><span class="tag">Status: <%= statusLunas %></span><% } %>
  </div>
  <% } %>

  <% 
    // Grouping data berdasarkan Lokasi
    const groupedByLokasi = transactions.reduce((acc, trx) => {
      const key = trx.kodelokasi || trx.namalokasi || 'NON-LOK';
      if (!acc[key]) {
        acc[key] = {
          kodelokasi: trx.kodelokasi || '-',
          nama      : trx.namalokasi || 'Tanpa Nama',
          listTrx   : [],
          totalPerLokasi: 0
        };
      }
      acc[key].listTrx.push(trx);
      acc[key].totalPerLokasi += Number(trx.grandtotal || 0);
      return acc;
    }, {});
  %>

  <% Object.keys(groupedByLokasi).forEach(function(kodeLok) { 
      let lokasi = groupedByLokasi[kodeLok];
  %>
    <!-- Header Oranye Per Lokasi -->
    <div class="lokasi-group-header">
      <div>
        <span class="tag-code"><%= lokasi.kodelokasi %></span>
        <span><%= lokasi.nama %></span>
      </div>
      <div style="font-size: 11px;">Total Transaksi: <%= lokasi.listTrx.length %></div>
    </div>

    <table>
      <thead>
        <tr>
          <th class="center" width="20">No</th>
          <th width="80">Kode Jual</th>
          <th class="center" width="60">Tanggal</th>
          <th>Customer</th>
          <th>Kode Brg</th>
          <th>Nama Barang</th>
          <th class="center">Qty</th>
          <th class="center">Sat</th>
          <th class="right">Harga</th>
          <th class="right">PPN</th>
          <th class="right">Subtotal</th>
          <th class="right">Grand Total</th>
          <th class="center">Jenis</th>
          <th class="center">Status</th>
        </tr>
      </thead>
      <tbody>
        <% lokasi.listTrx.forEach(function(trx, trxIdx) { %>
          <% trx.items.forEach(function(item, itemIdx) { %>
          <tr>
            <% if (itemIdx === 0) { %>
              <!-- Merge data transaksi -->
              <td class="center rs" rowspan="<%= trx.items.length %>"><%= trxIdx + 1 %></td>
              <td class="rs" rowspan="<%= trx.items.length %>"><%= trx.kodejual %></td>
              <td class="center rs" rowspan="<%= trx.items.length %>">
                <%= trx.tgltrans && trx.tgltrans.toISOString ? trx.tgltrans.toISOString().slice(0,10) : trx.tgltrans %>
              </td>
              <td class="rs" rowspan="<%= trx.items.length %>"><%= trx.namacustomer || '-' %></td>
            <% } %>

            <!-- Data Barang -->
            <td class="center item"><%= item.kodebarang %></td>
            <td class="item"><%= item.namabarang %></td>
            <td class="center item"><%= Number(item.jml) %></td>
            <td class="center item"><%= item.satuan %></td>
            <td class="right item"><%= Number(item.harga).toLocaleString('id-ID') %></td>
            <td class="right item"><%= Number(item.ppn).toLocaleString('id-ID') %></td>
            <td class="right item"><%= Number(item.subtotal).toLocaleString('id-ID') %></td>

            <% if (itemIdx === 0) { %>
              <!-- Merge data finansial -->
              <td class="right rs" rowspan="<%= trx.items.length %>"><%= Number(trx.grandtotal).toLocaleString('id-ID') %></td>
              <td class="center rs" rowspan="<%= trx.items.length %>"><%= trx.jenis || '-' %></td>
              <td class="center rs" rowspan="<%= trx.items.length %>">
                <span class="status-badge <%= trx.statusLunas === 'LUNAS' ? 'lunas' : 'belum' %>">
                  <%= trx.statusLunas %>
                </span>
              </td>
            <% } %>
          </tr>
          <% }); %>
        <% }); %>
      </tbody>
      <tfoot>
        <tr class="subtotal-row">
          <td colspan="11" class="right">TOTAL PENJUALAN <%= lokasi.nama %>:</td>
          <td class="right"><%= Number(lokasi.totalPerLokasi).toLocaleString('id-ID') %></td>
          <td colspan="2"></td>
        </tr>
      </tfoot>
    </table>
  <% }); %>

  <div class="grand-total-banner">
    <span>GRAND TOTAL KESELURUHAN</span>
    <span>Rp <%= Number(grandTotal).toLocaleString('id-ID') %></span>
  </div>

  <div class="report-footer" style="margin-top: 20px; text-align: center;">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
