<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Rekap Laporan Penjualan</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    .status-badge.lunas { background: #DCFCE7; color: #166534; }
    .status-badge.belum { background: #FEE2E2; color: #991B1B; }
    .filter-tags { margin-bottom: 8px; }
    .filter-tags .tag { display:inline-block; background:#FAEFE5; color:#C4683D; padding:2px 8px; border-radius:10px; font-size:10px; font-weight:600; margin:2px; }
    .summary-box { display:flex; gap:12px; margin-bottom:16px; flex-wrap:wrap; }
    .summary-box .card { flex:1; min-width:140px; padding:12px 16px; border-radius:8px; background:#FAEFE5; border:1px solid #D7CAC1; }
    .summary-box .card .label { font-size:10px; color:#998A76; font-weight:600; text-transform:uppercase; }
    .summary-box .card .value { font-size:16px; font-weight:700; color:#4B3E34; margin-top:4px; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>REKAP LAPORAN PENJUALAN</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <% if (kodelokasi || namalokasi || kodecustomer || namacustomer || statusLunas) { %>
  <div class="filter-tags">
    <% if (kodelokasi) { %><span class="tag">Lokasi: <%= kodelokasi %></span><% } %>
    <% if (namalokasi) { %><span class="tag">Lokasi: <%= namalokasi %></span><% } %>
    <% if (kodecustomer) { %><span class="tag">Customer: <%= kodecustomer %></span><% } %>
    <% if (namacustomer) { %><span class="tag">Customer: <%= namacustomer %></span><% } %>
    <% if (statusLunas) { %><span class="tag">Status: <%= statusLunas %></span><% } %>
  </div>
  <% } %>

  <div class="summary-box">
    <div class="card">
      <div class="label">Total Transaksi</div>
      <div class="value"><%= totalTransaksi %> transaksi</div>
    </div>
    <div class="card">
      <div class="label">Total Penjualan</div>
      <div class="value" <%= Number(totalPenjualan).toLocaleString('id-ID') %></div>
    </div>
    <div class="card">
      <div class="label">Total Lunas</div>
      <div class="value" <%= Number(totalLunas).toLocaleString('id-ID') %></div>
    </div>
    <div class="card">
      <div class="label">Total Piutang</div>
      <div class="value" <%= Number(totalPiutang).toLocaleString('id-ID') %></div>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th class="center">No</th>
        <th>Kode Jual</th>
        <th class="center">Tanggal</th>
        <th>Lokasi</th>
        <th>Customer</th>
        <th class="center">Item</th>
        <th class="right">Grand Total</th>
        <th class="right">Dibayar</th>
        <th class="right">Sisa</th>
        <th class="center">Status</th>
        <th class="center">Tgl Lunas</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(function(row, i) { %>
      <tr>
        <td class="center"><%= i + 1 %></td>
        <td><%= row.kodejual %></td>
        <td class="center"><%= row.tgltrans && row.tgltrans.toISOString ? row.tgltrans.toISOString().slice(0,10) : row.tgltrans %></td>
        <td><%= row.namalokasi || '-' %></td>
        <td><%= row.namacustomer || '-' %></td>
        <td class="center"><%= row.totalitem %></td>
        <td class="right" <%= Number(row.grandtotal).toLocaleString('id-ID') %></td>
        <td class="right" <%= Number(row.amount).toLocaleString('id-ID') %></td>
        <td class="right" <%= Number(row.sisa).toLocaleString('id-ID') %></td>
        <td class="center">
          <span class="status-badge <%= row.statusLunas === 'LUNAS' ? 'lunas' : 'belum' %>"><%= row.statusLunas %></span>
        </td>
        <td class="center"><%= row.tglpelunasan && row.tglpelunasan.toISOString ? row.tglpelunasan.toISOString().slice(0,10) : (row.tglpelunasan || '-') %></td>
      </tr>
      <% }); %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="5">TOTAL</td>
        <td class="center"><%= totalTransaksi %> transaksi</td>
        <td class="right"> <%= Number(totalPenjualan).toLocaleString('id-ID') %></td>
        <td class="right" colspan="4"></td>
      </tr>
    </tfoot>
  </table>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
