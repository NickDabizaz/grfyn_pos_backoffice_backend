<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Kartu Stok</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    table.barang-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 11px; }
    table.barang-table th, table.barang-table td { border: 1px solid #EBE3D9; padding: 6px; }
    table.barang-table th { background: #FAEFE5; color: #4B3E34; font-weight: 600; text-align: center; }
    .center { text-align: center; }
    .right { text-align: right; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN KARTU STOK</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <table class="barang-table">
    <thead>
      <tr>
        <th class="center" style="width: 5%;">No</th>
        <th style="width: 25%;">Nama Barang</th>
        <th class="right" style="width: 10%;">Masuk</th>
        <th class="right" style="width: 10%;">Keluar</th>
        <th class="right" style="width: 15%;">Saldo</th>
        <th style="width: 35%;">Keterangan</th>
      </tr>
    </thead>
    <tbody>
      <% 
        let currentBarangId = null;
        let saldo = 0;
        let i = 1;
        data.forEach(function(row) { 
          if (currentBarangId !== row.idbarang) {
            currentBarangId = row.idbarang;
            // Jika ada saldo awal di masa depan, kita set di sini.
            // Saat ini flat saldo mulai dari 0 jika tidak ada pre-kalkulasi
            saldo = 0; 
          }
          if (row.jenis === 'M') { saldo += parseInt(row.jml || 0); } else { saldo -= parseInt(row.jml || 0); }
      %>
      <tr>
        <td class="center"><%= i++ %></td>
        <td><%= row.namabarang %></td>
        <td class="right"><%= row.jenis === 'M' ? row.jml : '-' %></td>
        <td class="right"><%= row.jenis === 'K' ? row.jml : '-' %></td>
        <td class="right"><%= saldo %></td>
        <td><%= row.keterangan || '-' %> (<%= row.jenisref || '-' %>) - <%= new Date(row.tgltrans).toLocaleDateString('id-ID') %></td>
      </tr>
      <% }); %>
      <% if(data.length === 0) { %>
      <tr>
        <td colspan="6" class="center">Tidak ada data transaksi.</td>
      </tr>
      <% } %>
    </tbody>
  </table>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
