<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Kartu Stok</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    .barang-section { margin-bottom: 20px; page-break-inside: avoid; }
    .barang-title { font-size: 12px; font-weight: 700; color: #4B3E34; margin-bottom: 6px; padding: 6px; background: #FAEFE5; border-radius: 6px; }
    .barang-title span { color: #998A76; font-weight: 400; }
    table.barang-table { margin-bottom: 8px; }
    table.barang-table thead th { font-size: 9px; padding: 6px 4px; }
    table.barang-table tbody td { font-size: 10px; padding: 4px; }
    .summary-row td { font-weight: 600; background: #FDF8F2; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN KARTU STOK</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <% data.forEach(function(barang) { %>
  <div class="barang-section">
    <div class="barang-title">
      <%= barang.kodebarang %> | <%= barang.namabarang %> <span>(Satuan: <%= barang.satuankecil || '-' %>)</span>
    </div>
    <table class="barang-table">
      <thead>
        <tr>
          <th class="center">No</th>
          <th class="center">Tanggal</th>
          <th>Kode Transaksi</th>
          <th>Keterangan</th>
          <th class="center">Jenis</th>
          <th class="right">Masuk</th>
          <th class="right">Keluar</th>
          <th class="right">Saldo</th>
        </tr>
      </thead>
      <tbody>
        <% let saldo = barang.saldo_awal; %>
        <tr class="summary-row">
          <td colspan="7" style="text-align:right;">Saldo Awal</td>
          <td class="right"><%= saldo %></td>
        </tr>
        <% barang.items.forEach(function(row, i) { %>
          <% if (row.jenis === 'M') { saldo += parseInt(row.jml || 0); } else { saldo -= parseInt(row.jml || 0); } %>
        <tr>
          <td class="center"><%= i + 1 %></td>
          <td class="center"><%= new Date(row.tgltrans).toLocaleDateString('id-ID') %></td>
          <td><%= row.kodetrans %></td>
          <td><%= row.keterangan || '-' %></td>
          <td class="center"><%= row.jenis === 'M' ? 'Masuk' : 'Keluar' %></td>
          <td class="right"><%= row.jenis === 'M' ? row.jml : '-' %></td>
          <td class="right"><%= row.jenis === 'K' ? row.jml : '-' %></td>
          <td class="right"><%= saldo %></td>
        </tr>
        <% }); %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="5">TOTAL PERGERAKAN</td>
          <td class="right"><%= barang.total_masuk %></td>
          <td class="right"><%= barang.total_keluar %></td>
          <td class="right"><%= saldo %></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% }); %>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
