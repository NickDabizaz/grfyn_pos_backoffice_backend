<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Kartu Stok</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    .barang-section { margin-top: 18px; page-break-inside: avoid; }
    .barang-title { margin: 0 0 6px 0; font-size: 13px; font-weight: 700; color: #4B3E34; text-transform: uppercase; }
    table.barang-table { width: 100%; border-collapse: collapse; font-size: 11px; }
    table.barang-table th, table.barang-table td { border: 1px solid #EBE3D9; padding: 6px; }
    table.barang-table th { background: #FAEFE5; color: #4B3E34; font-weight: 600; text-align: center; }
    table.barang-table tbody tr:nth-child(even) { background: #FCF8F3; }
    table.barang-table .saldo-awal td { font-weight: 600; background: #FFF9F2; }
    .center { text-align: center; }
    .right { text-align: right; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN KARTU STOK</h3>
  </div>

  <%
    const sections = groupedData || [];
    const formatQty = function(value) {
      const number = Number(value || 0);
      return number.toLocaleString('id-ID', { minimumFractionDigits: 3, maximumFractionDigits: 3 });
    };
    const formatTanggal = function(value) {
      if (!value) return '-';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return date.toLocaleDateString('id-ID');
    };
  %>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <% if(sections.length === 0) { %>
    <table class="barang-table" style="margin-top:20px;">
      <tbody>
        <tr>
          <td class="center">Tidak ada data transaksi.</td>
        </tr>
      </tbody>
    </table>
  <% } %>

  <% sections.forEach(function(section) { %>
    <div class="barang-section">
      <h4 class="barang-title"><%= section.namabarang %> (<%= section.kodebarang || '-' %>) - <%= section.satuan || '-' %></h4>
      <table class="barang-table">
        <thead>
          <tr>
            <th class="center" style="width: 5%;">No</th>
            <th class="center" style="width: 11%;">Tanggal</th>
            <th style="width: 15%;">Lokasi</th>
            <th class="right" style="width: 12%;">Masuk</th>
            <th class="right" style="width: 12%;">Keluar</th>
            <th class="right" style="width: 13%;">Saldo</th>
            <th style="width: 32%;">Keterangan</th>
          </tr>
        </thead>
        <tbody>
          <%
            let saldo = Number(section.saldoAwal || 0);
            let i = 1;
          %>
          <tr class="saldo-awal">
            <td class="center"><%= i++ %></td>
            <td class="center">-</td>
            <td><%= namalokasi || '-' %></td>
            <td class="right">-</td>
            <td class="right">-</td>
            <td class="right"><%= formatQty(saldo) %></td>
            <td>SALDO AWAL</td>
          </tr>
          <% section.rows.forEach(function(row) {
            const jumlah = Number(row.jml || 0);
            if (row.jenis === 'M') { saldo += jumlah; } else if (row.jenis === 'K') { saldo -= jumlah; }
          %>
            <tr>
              <td class="center"><%= i++ %></td>
              <td class="center"><%= formatTanggal(row.tgltrans) %></td>
              <td><%= row.namalokasi || namalokasi || '-' %></td>
              <td class="right"><%= row.jenis === 'M' ? formatQty(row.jml) : '-' %></td>
              <td class="right"><%= row.jenis === 'K' ? formatQty(row.jml) : '-' %></td>
              <td class="right"><%= formatQty(saldo) %></td>
              <td><%= row.keterangan || '-' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% }); %>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
