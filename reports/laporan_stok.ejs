<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Stok</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    .stok-warning { color: #DC2626; font-weight: 700; }
    .stok-ok { color: #16A34A; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#E76F51;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN STOK</h3>
  </div>

  <div class="report-meta">
    <span>Periode Saldo: <span class="periode"><%= periodSaldo %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <table>
    <thead>
      <tr>
        <th class="center">No</th>
        <th>Kode</th>
        <th>Nama Barang</th>
        <th class="center">Satuan</th>
        <th class="center">Stok Min</th>
        <th class="center">Stok</th>
        <th class="center">Status</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(function(row, i) { %>
      <tr>
        <td class="center"><%= i + 1 %></td>
        <td><%= row.kodebarang %></td>
        <td><%= row.namabarang %></td>
        <td class="center"><%= row.satuan || '-' %></td>
        <td class="center"><%= row.stokmin || 0 %></td>
        <td class="center <%= (row.stok || 0) <= (row.stokmin || 0) ? 'stok-warning' : 'stok-ok' %>"><%= row.stok || 0 %></td>
        <td class="center"><%= (row.stok || 0) <= (row.stokmin || 0) ? '⚠ MENIPIS' : 'OK' %></td>
      </tr>
      <% }); %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="5">TOTAL (<%= totalBarang %> Barang)</td>
        <td class="center"><%= totalStok %></td>
        <td></td>
      </tr>
    </tfoot>
  </table>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
