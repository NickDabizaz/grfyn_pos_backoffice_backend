<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Absen</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    table { width: 100%; border-collapse: collapse; }
    th, td { border: 1px solid #D7CAC1; padding: 7px; font-size: 11px; }
    .center { text-align: center; }
    .badge { font-weight: 700; font-size: 10px; padding: 2px 6px; border-radius: 8px; background: #FAEFE5; color: #9A4C2D; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN ABSEN</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <table>
    <thead>
      <tr>
        <th class="center">No</th>
        <th>Tanggal</th>
        <th>Kode Absen</th>
        <th>Lokasi</th>
        <th>Kode Karyawan</th>
        <th>Nama Karyawan</th>
        <th class="center">Jenis</th>
        <th>Catatan</th>
        <th class="center">Status</th>
      </tr>
    </thead>
    <tbody>
      <% let no = 0; %>
      <% groups.forEach(function(group) { no++; %>
        <% group.items.forEach(function(item, idx) { %>
        <tr>
          <% if (idx === 0) { %>
            <td class="center" rowspan="<%= group.items.length %>"><%= no %></td>
            <td rowspan="<%= group.items.length %>"><%= group.tgltrans %></td>
            <td rowspan="<%= group.items.length %>"><%= group.kodeabsen %></td>
            <td rowspan="<%= group.items.length %>"><%= group.namalokasi || '-' %></td>
          <% } %>
          <td><%= item.kodekaryawan || '-' %></td>
          <td><%= item.namakaryawan || '-' %></td>
          <td class="center"><span class="badge"><%= item.jenis %></span></td>
          <td><%= item.catatan || '-' %></td>
          <% if (idx === 0) { %>
            <td class="center" rowspan="<%= group.items.length %>"><%= group.status %></td>
          <% } %>
        </tr>
        <% }); %>
      <% }); %>
      <% if (!groups.length) { %>
        <tr><td colspan="9" class="center">Tidak ada data</td></tr>
      <% } %>
    </tbody>
    <tfoot>
      <tr style="background:#FAEFE5;font-weight:700;">
        <td colspan="9">Total: <%= totalTransaksi %> transaksi, <%= totalDetail %> detail karyawan</td>
      </tr>
    </tfoot>
  </table>
</body>
</html>
