<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Laporan Sales Per Barang</title>
  <link rel="stylesheet" href="/reports/laporan_style.css">
  <style>
    @media print { .no-print { display: none; } }
    .filter-tags { margin-bottom: 8px; }
    .filter-tags .tag { display:inline-block; background:#FAEFE5; color:#C4683D; padding:2px 8px; border-radius:10px; font-size:10px; font-weight:600; margin:2px; }
  </style>
</head>
<body>
  <div class="no-print" style="text-align:right;margin-bottom:10px;">
    <button onclick="window.print()" style="padding:8px 16px;background:#C4683D;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Cetak</button>
  </div>

  <div class="report-header">
    <% if (logo) { %><img class="logo" src="<%= logo %>" alt="Logo"><% } %>
    <h2><%= namatoko %></h2>
    <p class="subtitle"><%= alamat %> | <%= hp %></p>
    <h3>LAPORAN SALES PER BARANG</h3>
  </div>

  <div class="report-meta">
    <span>Periode: <span class="periode"><%= tglwal %> s/d <%= tglakhir %></span></span>
    <span>Tanggal Cetak: <%= tglcetak %></span>
  </div>

  <% if (kodelokasi || namalokasi || kodecustomer || namacustomer || statusLunas) { %>
  <div class="filter-tags">
    <% if (kodelokasi) { %><span class="tag">Lokasi: <%= kodelokasi %></span><% } %>
    <% if (namalokasi) { %><span class="tag">Lokasi: <%= namalokasi %></span><% } %>
    <% if (kodecustomer) { %><span class="tag">Customer: <%= kodecustomer %></span><% } %>
    <% if (namacustomer) { %><span class="tag">Customer: <%= namacustomer %></span><% } %>
    <% if (statusLunas) { %><span class="tag">Status: <%= statusLunas %></span><% } %>
  </div>
  <% } %>

  <%
    // Grouping data per barang di sisi EJS
    const groups = {};
    const groupOrder = [];
    data.forEach(function(row) {
      const key = row.kodebarang || row.namabarang;
      if (!groups[key]) {
        groups[key] = {
          kodebarang : row.kodebarang,
          namabarang : row.namabarang,
          satuan     : row.satuan,
          items      : [],
          total_qty  : 0,
          total_nilai: 0
        };
        groupOrder.push(key);
      }
      groups[key].items.push(row);
      groups[key].total_qty   += Number(row.jml || 0);
      groups[key].total_nilai += Number(row.subtotal || 0);
    });
  %>

  <% if (groupOrder.length === 0) { %>
    <p style="text-align:center;color:#998A76;padding:20px;">Tidak ada data untuk periode ini.</p>
  <% } %>

  <% groupOrder.forEach(function(key) { %>
  <% var grp = groups[key]; %>
  <div class="group-block">
    <div class="group-header">
      <span class="group-label"><%= grp.kodebarang || '-' %></span>
      <span class="group-title"><%= grp.namabarang %></span>
      <span class="group-sub">Satuan: <%= grp.satuan || '-' %></span>
    </div>
    <table>
      <thead>
        <tr>
          <th class="center">No</th>
          <th>No. Jual</th>
          <th class="center">Tgl Transaksi</th>
          <th>Customer</th>
          <th>Lokasi</th>
          <th class="center">Jenis</th>
          <th class="center">Qty</th>
          <th class="right">Harga Satuan</th>
          <th class="right">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% grp.items.forEach(function(item, i) { %>
        <tr>
          <td class="center"><%= i + 1 %></td>
          <td><%= item.kodejual || '-' %></td>
          <td class="center"><%= item.tgltrans ? new Date(item.tgltrans).toLocaleDateString('id-ID') : '-' %></td>
          <td><%= item.namacustomer || '-' %></td>
          <td><%= item.namalokasi || '-' %></td>
          <td class="center"><%= item.jenis || '-' %></td>
          <td class="center"><%= item.jml || 0 %></td>
          <td class="right">Rp <%= Number(item.harga || 0).toLocaleString('id-ID') %></td>
          <td class="right">Rp <%= Number(item.subtotal || 0).toLocaleString('id-ID') %></td>
        </tr>
        <% }); %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="6" style="text-align:right;">Subtotal <%= grp.namabarang %>:</td>
          <td class="center"><strong><%= grp.total_qty %></strong></td>
          <td></td>
          <td class="right"><strong>Rp <%= Number(grp.total_nilai).toLocaleString('id-ID') %></strong></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% }); %>

  <div class="grand-total-block">
    <span>GRAND TOTAL PENJUALAN</span>
    <span>Rp <%= Number(grandTotal).toLocaleString('id-ID') %></span>
  </div>

  <div class="report-footer">
    <p>&copy; <%= namatoko %> - Generated by Grfyn POS</p>
  </div>
</body>
</html>
